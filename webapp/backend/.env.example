# Segurança JWT
SECRET_KEY=troque-por-uma-chave-forte-com-pelo-menos-32-caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Banco de dados
# Produção (Railway PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/unacob

# Desenvolvimento local (SQLite):
DATABASE_URL=sqlite:///./associacao.db

# Produção Docker no VPS (SQLite persistente em volume):
# DATABASE_URL=sqlite:////data/associacao.db

# Frontend público (usado para links de convite)
# Exemplo produção: FRONTEND_URL=https://unacobadmin.com.br
FRONTEND_URL=https://unacobadmin.com.br
# Opcional (tem prioridade sobre FRONTEND_URL)
FRONTEND_BASE_URL=https://unacobadmin.com.br
# URL pública do logo exibido no e-mail de convite da festa (opcional)
EMAIL_LOGO_URL=
# URL pública de imagem temática de festa no topo do convite (opcional)
EMAIL_FESTA_IMAGE_URL=

# Configurações de Email (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-ou-app-password
SMTP_FROM_NAME=UNACOB Festas
SMTP_FROM_EMAIL=seu-email@gmail.com
SMTP_STARTTLS=true
# Use true para provedores na porta 465 (SSL direto)
SMTP_SSL=false







