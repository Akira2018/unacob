# Segurança JWT
SECRET_KEY=troque-por-uma-chave-forte-com-pelo-menos-32-caracteres
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Banco de dados
# Exemplo SQLite local
DATABASE_URL=sqlite:///./associacao.db

# Exemplo PostgreSQL (produção)
# DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/unacob

# Frontend (origem principal)
FRONTEND_URL=http://localhost:5173

# E-mail (opcional para notificações)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-ou-app-password
SMTP_FROM_NAME=UNACOB
SMTP_FROM_EMAIL=seu-email@gmail.com
SMTP_STARTTLS=true
